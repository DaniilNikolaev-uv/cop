pkgname=cop
pkgver=0.1.0
pkgrel=1
pkgdesc="cat-like utility that copies output to clipboard"
arch=('x86_64')
url="https://github.com/DaniilNikolaev-uv/cop"
license=('MIT')
depends=('xclip' 'wl-clipboard')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/DaniilNikolaev-uv/cop/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname-$pkgver"
  cargo build --release
}

package() {
  cd "$srcdir/$pkgname-$pkgver"
  install -Dm755 target/release/cop "$pkgdir/usr/bin/cop"
}
